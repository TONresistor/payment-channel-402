{
  "name": "pc402-fetch",
  "version": "0.3.0",
  "description": "HTTP client with automatic 402 payment channel handling",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pc402-core": "*",
    "pc402-channel": "*",
    "@ton/ton": ">=15.0.0"
  },
  "peerDependencies": {
    "@ton/core": ">=0.60.0",
    "@ton/crypto": ">=3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TONresistor/payment-channel-402"
  }
}
